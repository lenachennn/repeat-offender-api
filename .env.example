# Port, auf dem die API lauscht
PORT=8787

# Geheimer Schluessel - muss in der Chatty-Konfiguration identisch sein
API_KEY=

# Eskalations-Stufen in Sekunden (kommagetrennt).
# Beim 1. Mal die erste Zahl, beim 2. Mal die zweite usw. Danach bleibt die letzte.
# 60=1min, 300=5min, 600=10min, 3600=1h, 86400=1d, 604800=7d, 1209600=14d (Twitch-Maximum)
TIERS=60,300,600,3600,86400,604800,1209600

# Nach so vielen Tagen ohne neuen Verstoss wird der Zaehler zurueckgesetzt (0 = nie)
DECAY_DAYS=30
